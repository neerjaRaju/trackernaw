# --- Database ---
DATABASE_URL=postgresql://fieldforce:fieldforce@localhost:5432/fieldforce
POSTGRES_USER=fieldforce
POSTGRES_PASSWORD=fieldforce
POSTGRES_DB=fieldforce

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Server ---
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# --- AWS / S3 ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=fieldforce-uploads

# --- Firebase ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Twilio (SMS) ---
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- SendGrid (email) ---
SENDGRID_API_KEY=
EMAIL_FROM=noreply@fieldforce.app

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=

# --- SSO (OIDC) ---
SSO_REDIRECT_BASE=http://localhost:4000
ADMIN_PANEL_URL=http://localhost:5173
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SALESFORCE_DOMAIN=login.salesforce.com
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_LOCATION_TOPIC=location-events
KAFKA_GROUP_ID=fieldforce-consumers
